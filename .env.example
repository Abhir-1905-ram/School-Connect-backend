PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/school-connect?appName=Cluster0
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d
# Frontend origin(s) for CORS — comma-separated for multiple (e.g. Vercel + local)
CLIENT_URL=http://localhost:3000
# Production example:
# CLIENT_URL=https://school-connect-frontend-zveb.vercel.app,http://localhost:3000
NODE_ENV=development
